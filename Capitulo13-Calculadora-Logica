from tkinter import *

root = Tk()

def escribir(valor):
    actual = pantalla.get()
    pantalla.delete(0,END)
    pantalla.insert(0,str(actual)+str(valor))

pantalla = Entry(root,width=25)
pantalla.grid(row=0,column=0,columnspan=3)

Button(root,text="1",command=lambda:escribir(1)).grid(row=1,column=0)
Button(root,text="2",command=lambda:escribir(2)).grid(row=1,column=1)
Button(root,text="3",command=lambda:escribir(3)).grid(row=1,column=2)

root.mainloop()